<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="1080.0" prefWidth="1600.0" style="-fx-background-color:#16213e;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.orm_project.controller.PaymentController">
    <children>

        <VBox layoutX="370.0" layoutY="79.0" prefHeight="562.0" prefWidth="416.0" spacing="12" style="-fx-background-color:white;-fx-padding:20;                      -fx-background-radius:12;-fx-border-color:#e8e6f8;-fx-border-radius:12;">

            <Label style="-fx-font-size:18;-fx-font-weight:bold;-fx-text-fill:#26215c;" text="Payment Management" />
            <Label fx:id="lblMessage" text="" />
            <Label text="ID" />
            <TextField fx:id="txtId" editable="false" />
            <Label text="Registration" />
            <ComboBox fx:id="cmbRegistration" prefWidth="300" />
            <Label text="Payment Date" />
            <DatePicker fx:id="dpPaymentDate" />
            <Label text="Amount" />
            <TextField fx:id="txtAmount" promptText="Enter amount" />
            <Label text="Status" />
            <ComboBox fx:id="cmbStatus" prefWidth="300" />

            <HBox spacing="8">
                <Button fx:id="btnSave" onAction="#handleSave" style="-fx-background-color:#7f77dd;-fx-text-fill:white;                                -fx-background-radius:8;-fx-cursor:hand;" text="Save" />
                <Button onAction="#handleClear" style="-fx-background-color:#e74c3c;-fx-text-fill:white;                                -fx-background-radius:8;-fx-cursor:hand;" text="Delete" />
                <Button onAction="#handleClear" style="-fx-background-color:#888;-fx-text-fill:white;                                -fx-background-radius:8;-fx-cursor:hand;" text="Reset" />
            </HBox>

            <Button onAction="#handleReportView" prefWidth="300" style="-fx-background-color:#1d9e75;-fx-text-fill:white;                            -fx-font-weight:bold;-fx-background-radius:8;-fx-cursor:hand;" text="Report View" />
        </VBox>

        <VBox layoutX="794.0" layoutY="79.0" prefWidth="570" spacing="10" style="-fx-background-color:white;-fx-padding:20;                      -fx-background-radius:12;-fx-border-color:#e8e6f8;-fx-border-radius:12;">

            <Label style="-fx-font-size:16;-fx-font-weight:bold;-fx-text-fill:#26215c;" text="Payment List" />
            <TextField fx:id="txtSearch" promptText="Search payment..." style="-fx-background-radius:8;" />

            <TableView fx:id="tblPayment" prefHeight="450.0" prefWidth="552.0">
                <columns>
                    <TableColumn fx:id="colId" prefWidth="80" text="ID" />
                    <TableColumn fx:id="colRegistration" prefWidth="120.0" text="Reg ID" />
                    <TableColumn fx:id="colDate" prefWidth="91.0" text="Date" />
                    <TableColumn fx:id="colAmount" prefWidth="129.0" text="Amount" />
                    <TableColumn fx:id="colStatus" prefWidth="130.0" text="Status" />
                    <TableColumn fx:id="colAction" prefWidth="90.0" text="Action" />
                </columns>
            </TableView>
        </VBox>
      <VBox layoutX="1364.0" layoutY="170.0" prefHeight="200.0" prefWidth="269.0" />

    </children>
</AnchorPane>
