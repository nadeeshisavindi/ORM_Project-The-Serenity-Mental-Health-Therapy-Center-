<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="1080" prefWidth="1600" style="-fx-background-color:#16213e;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.orm_project.controller.RegistrationController">

    <children>


        <VBox layoutX="382.0" layoutY="76.0" prefHeight="590.0" prefWidth="350" spacing="12" style="-fx-background-color:white;                      -fx-padding:20;                      -fx-background-radius:12;                      -fx-border-color:#e8e6f8;                      -fx-border-radius:12;">

            <Label style="-fx-font-size:18;-fx-font-weight:bold;-fx-text-fill:#26215c;" text="Registration Management" />

            <Label fx:id="lblMessage" managed="false" prefWidth="310" text="" visible="false" wrapText="true" />

            <Label text="ID" />
            <TextField fx:id="txtId" editable="false" />

            <Label text="Patient" />
            <ComboBox fx:id="cmbPatient" prefWidth="300" />

            <Label text="Therapy Program" />
            <ComboBox fx:id="cmbProgram" prefWidth="300" />

            <Label text="Registration Date" />
            <DatePicker fx:id="dpRegistrationDate" prefWidth="300" />

            <Label text="Amount Paid (LKR)" />
            <TextField fx:id="txtAmountPaid" promptText="Enter amount" />

            <HBox spacing="8">
                <Button fx:id="btnSave" onAction="#handleSave" prefHeight="25.0" prefWidth="94.0" style="-fx-background-color:#7f77dd;-fx-text-fill:white;" text="Save" />
                <Button onAction="#handleClear" prefHeight="25.0" prefWidth="95.0" style="-fx-background-color:#e74c3c;-fx-text-fill:white;" text="Delete" />
                <Button onAction="#handleClear" prefHeight="25.0" prefWidth="109.0" style="-fx-background-color:#888;-fx-text-fill:white;" text="Reset" />
            </HBox>

        </VBox>





        <VBox layoutX="751.0" layoutY="76.0" prefHeight="590.0" prefWidth="580" spacing="10" style="-fx-background-color:white;                      -fx-padding:20;                      -fx-background-radius:12;                      -fx-border-color:#e8e6f8;                      -fx-border-radius:12;">

            <Label style="-fx-font-size:16;-fx-font-weight:bold;-fx-text-fill:#26215c;" text="Registration List" />

            <TextField fx:id="txtSearch" promptText="Search registration..." style="-fx-background-radius:8;" />

            <TableView fx:id="tblRegistration" prefHeight="450">
                <columns>
                    <TableColumn fx:id="colId" prefWidth="75" text="ID" />
                    <TableColumn fx:id="colPatient" prefWidth="130" text="Patient" />
                    <TableColumn fx:id="colProgram" prefWidth="130" text="Program" />
                    <TableColumn fx:id="colDate" prefWidth="100" text="Date" />
                    <TableColumn fx:id="colAmount" prefWidth="110" text="Amount (LKR)" />
                    <TableColumn fx:id="colAction" prefWidth="140" text="Actions" />
                </columns>
            </TableView>

        </VBox>

    </children>
</AnchorPane>
