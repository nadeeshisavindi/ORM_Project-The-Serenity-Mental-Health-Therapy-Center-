<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="1080" prefWidth="1600" style="-fx-background-color:#16213e;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.orm_project.controller.TherapistController">

    <children>

        <!-- LEFT FORM PANEL -->
        <VBox layoutX="382.0" layoutY="76.0" prefHeight="552.0" prefWidth="350" spacing="12" style="-fx-background-color:white;                      -fx-padding:20;                      -fx-background-radius:12;                      -fx-border-color:#e8e6f8;                      -fx-border-radius:12;">

            <Label style="-fx-font-size:18; -fx-font-weight:bold; -fx-text-fill:#26215c;" text="Therapist Management" />

            <Label fx:id="lblMessage" text="" />

            <Label text="ID" />
            <TextField fx:id="txtId" editable="false" />

            <Label text="Name" />
            <TextField fx:id="txtName" promptText="Enter name" />

            <Label text="Specialization" />
            <ComboBox fx:id="cmbSpecialization" prefWidth="300" />

            <Label text="Phone" />
            <TextField fx:id="txtPhone" promptText="Enter phone" />

            <Label text="Email" />
            <TextField fx:id="txtEmail" promptText="Enter email" />

            <Label text="Availability" />
            <ComboBox fx:id="cmbAvailability" prefWidth="300" />

            <!-- ACTION BUTTONS -->
            <HBox spacing="8">

                <Button fx:id="btnSave" onAction="#handleSave" style="-fx-background-color:#7f77dd; -fx-text-fill:white;" text="Save" />

                <Button onAction="#handleDelete" style="-fx-background-color:#e74c3c; -fx-text-fill:white;" text="Delete" />

                <Button onAction="#handleClear" style="-fx-background-color:#888; -fx-text-fill:white;" text="Reset" />

            </HBox>

            <!-- REPORT BUTTON -->
            <Button onAction="#handleReportView" prefWidth="300" style="-fx-background-color:#1d9e75;                            -fx-text-fill:white;                            -fx-font-weight:bold;                            -fx-background-radius:8;                            -fx-cursor:hand;" text="Report View" />

        </VBox>

        <!-- RIGHT TABLE PANEL -->
        <VBox layoutX="751.0" layoutY="76.0" prefHeight="568.0" prefWidth="580" spacing="10" style="-fx-background-color:white;                      -fx-padding:20;                      -fx-background-radius:12;                      -fx-border-color:#e8e6f8;                      -fx-border-radius:12;">

            <Label style="-fx-font-size:16; -fx-font-weight:bold;" text="Therapist List" />

            <TextField fx:id="txtSearch" promptText="Search therapist..." style="-fx-background-radius:8;" />

            <TableView fx:id="tblTherapist" prefHeight="450">
                <columns>
                    <TableColumn fx:id="colId" prefWidth="80" text="ID" />
                    <TableColumn fx:id="colName" prefWidth="120" text="Name" />
                    <TableColumn fx:id="colEmail" prefWidth="140" text="Email" />
                    <TableColumn fx:id="colPhone" prefWidth="100" text="Phone" />
                    <TableColumn fx:id="colSpecialization" prefWidth="130" text="Specialization" />
                    <TableColumn fx:id="colAction" prefWidth="100" text="Action" />
                </columns>
            </TableView>

        </VBox>

    </children>

</AnchorPane>
