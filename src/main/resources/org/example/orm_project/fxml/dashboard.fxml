<AnchorPane fx:id="contentPane" style="-fx-background-color: #16213e;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.orm_project.controller.DashboardController">

    <children>

        <!-- MAIN CONTENT -->
        <VBox fx:id="mainContent" prefHeight="636.0" prefWidth="962.0" style="-fx-background-color: #16213e;">


        </VBox>

        <!-- LEFT MENU -->
        <VBox layoutX="-3.0" prefHeight="636.0" prefWidth="275.0" style="-fx-background-color: #16213e; -fx-padding: 20 14 20 14;">

            <children>
                <VBox prefHeight="145.0" prefWidth="247.0">
                    <children>
                        <VBox prefHeight="45.0" prefWidth="247.0">
                            <children>
                                <Label prefHeight="45.0" prefWidth="244.0" text="Serenity Wellness " textFill="WHITE">
                                    <font>
                                        <Font name="System Bold" size="28.0" />
                                    </font>
                                </Label>
                            </children>
                        </VBox>
                        <Label prefHeight="45.0" prefWidth="212.0" text="Clinic...." textFill="WHITE">
                            <font>
                                <Font name="System Bold" size="28.0" />
                            </font>
                        </Label>
                        <Label style="-fx-text-fill: #534ab7; -fx-font-size: 10;" text="Mental Therapy Center" textFill="WHITE" />

                        <Separator prefHeight="7.0" prefWidth="247.0" />
                    </children>
                </VBox>
                <VBox prefHeight="325.0" prefWidth="247.0">
                    <children>

                        <Label style="-fx-text-fill: #534ab7; -fx-font-size: 10; -fx-font-weight: bold;" text="MANAGEMENT" />

                        <Button maxWidth="Infinity" onAction="#navigateToPatient" prefHeight="41.0" prefWidth="247.0" style="-fx-background-color: rgba(127,119,221,0.18); -fx-text-fill: #b4b2a9;" text="👤   Patients">
                            <VBox.margin>
                                <Insets top="10.0" />
                            </VBox.margin>
                     <font>
                        <Font size="16.0" />
                     </font>
                        </Button>

                        <Button maxWidth="Infinity" onAction="#navigateToTherapists" prefHeight="41.0" prefWidth="247.0" style="-fx-background-color: rgba(127,119,221,0.18); -fx-text-fill: #b4b2a9;" text="🩺   Therapists">
                            <VBox.margin>
                                <Insets top="10.0" />
                            </VBox.margin>
                     <font>
                        <Font size="16.0" />
                     </font>
                        </Button>

                        <Button maxWidth="Infinity" onAction="#navigateToSessions" prefHeight="43.0" prefWidth="247.0" style="-fx-background-color: rgba(127,119,221,0.18); -fx-text-fill: #b4b2a9;" text="📅   Sessions">
                            <VBox.margin>
                                <Insets top="10.0" />
                            </VBox.margin>
                     <font>
                        <Font size="16.0" />
                     </font>
                        </Button>

                        <Button maxWidth="Infinity" onAction="#navigateToPrograms" prefHeight="44.0" prefWidth="247.0" style="-fx-background-color: rgba(127,119,221,0.18); -fx-text-fill: #b4b2a9;" text="📋   Programs">
                            <VBox.margin>
                                <Insets top="10.0" />
                            </VBox.margin>
                     <font>
                        <Font size="16.0" />
                     </font>
                        </Button>

                        <Button maxWidth="Infinity" onAction="#navigateToPayment" prefHeight="42.0" prefWidth="247.0" style="-fx-background-color: rgba(127,119,221,0.18); -fx-text-fill: #b4b2a9;" text="💳   Payments">
                            <VBox.margin>
                                <Insets top="10.0" />
                            </VBox.margin>
                     <font>
                        <Font size="16.0" />
                     </font>
                        </Button>
                    </children>
                </VBox>

                <Label style="-fx-text-fill: #534ab7; -fx-font-size: 10; -fx-font-weight: bold;" text="SYSTEM" />

                <HBox alignment="CENTER_LEFT" prefHeight="70.0" prefWidth="247.0" spacing="10">
                    <children>
                        <VBox prefHeight="0.0" prefWidth="247.0" spacing="2">
                            <children>
                                <VBox prefHeight="34.0" prefWidth="247.0">
                           <children>

                                              <Button maxWidth="Infinity" onAction="#logout" prefHeight="50.0" prefWidth="247.0" style="-fx-background-color: rgba(127,119,221,0.18); -fx-text-fill: #b4b2a9;" text="Log out">
                                 <font>
                                    <Font size="16.0" />
                                 </font>
                              </Button>
                           </children></VBox>
                            </children>
                        </VBox>
                    </children>
                </HBox>

            </children>
        </VBox>

    </children>

</AnchorPane>
