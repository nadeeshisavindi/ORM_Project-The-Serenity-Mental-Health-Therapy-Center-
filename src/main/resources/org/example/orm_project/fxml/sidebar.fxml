<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="700.0"
      prefWidth="260.0"
      style="-fx-background-color:#16213e;
             -fx-padding:20;"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.example.orm_project.controller.SidebarController">

    <children>

        <!-- LOGO -->

        <VBox spacing="5">

            <children>

                <Label text="Serenity Wellness"
                       textFill="WHITE">

                    <font>
                        <Font size="28.0"/>
                    </font>

                </Label>

                <Label text="Clinic"
                       textFill="WHITE">

                    <font>
                        <Font size="34.0"/>
                    </font>

                </Label>

                <Label text="Mental Therapy Center"
                       style="-fx-text-fill:#8f87ff;
                              -fx-font-size:11;" />

                <Separator prefWidth="220.0"/>

            </children>

        </VBox>

        <!-- OVERVIEW -->

        <VBox spacing="10">

            <children>

                <Label text="OVERVIEW"
                       style="-fx-text-fill:#7f77dd;
                              -fx-font-size:10;
                              -fx-font-weight:bold;" />

                <Button text="⊞ Dashboard"
                        maxWidth="Infinity"
                        onAction="#navigateToDashboard"
                        style="-fx-background-color:#7f77dd;
                               -fx-text-fill:white;
                               -fx-background-radius:10;
                               -fx-font-weight:bold;" />

            </children>

            <padding>
                <Insets top="20"/>
            </padding>

        </VBox>

        <!-- MANAGEMENT -->

        <VBox spacing="12">

            <children>

                <Label text="MANAGEMENT"
                       style="-fx-text-fill:#7f77dd;
                              -fx-font-size:10;
                              -fx-font-weight:bold;" />

                <Button text="👤 Patients"
                        maxWidth="Infinity"
                        onAction="#navigateToPatient"
                        style="-fx-background-color:#232b4a;
                               -fx-text-fill:#d6d3ff;
                               -fx-background-radius:10;" />

                <Button text="🩺 Therapists"
                        maxWidth="Infinity"
                        onAction="#navigateToTherapists"
                        style="-fx-background-color:#232b4a;
                               -fx-text-fill:#d6d3ff;
                               -fx-background-radius:10;" />

                <Button text="📅 Sessions"
                        maxWidth="Infinity"
                        onAction="#navigateToSessions"
                        style="-fx-background-color:#232b4a;
                               -fx-text-fill:#d6d3ff;
                               -fx-background-radius:10;" />

                <Button text="📋 Programs"
                        maxWidth="Infinity"
                        onAction="#navigateToPrograms"
                        style="-fx-background-color:#232b4a;
                               -fx-text-fill:#d6d3ff;
                               -fx-background-radius:10;" />

                <Button text="💳 Payments"
                        maxWidth="Infinity"
                        onAction="#navigateToPayment"
                        style="-fx-background-color:#232b4a;
                               -fx-text-fill:#d6d3ff;
                               -fx-background-radius:10;" />

            </children>

            <padding>
                <Insets top="25"/>
            </padding>

        </VBox>

        <!-- SYSTEM -->

        <VBox spacing="10">

            <children>

                <Label text="SYSTEM"
                       style="-fx-text-fill:#7f77dd;
                              -fx-font-size:10;
                              -fx-font-weight:bold;" />

                <Button text="Logout"
                        maxWidth="Infinity"
                        onAction="#navigateToUser"
                        style="-fx-background-color:#e74c3c;
                               -fx-text-fill:white;
                               -fx-background-radius:10;
                               -fx-font-weight:bold;" />

            </children>

            <padding>
                <Insets top="30"/>
            </padding>

        </VBox>

    </children>

</VBox>