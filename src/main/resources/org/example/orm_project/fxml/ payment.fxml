<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="600" prefWidth="1000"
            style="-fx-background-color:#16213e;"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.orm_project.controller.PaymentController">

    <children>

        <!-- LEFT FORM PANEL -->
        <VBox layoutX="25" layoutY="20" prefWidth="350" spacing="12"
              style="-fx-background-color:white;
                     -fx-padding:20;
                     -fx-background-radius:12;
                     -fx-border-color:#e8e6f8;
                     -fx-border-radius:12;">

            <Label text="Payment Management"
                   style="-fx-font-size:18; -fx-font-weight:bold; -fx-text-fill:#26215c;"/>

            <Label fx:id="lblMessage" visible="false"/>

            <Label text="ID"/>
            <TextField fx:id="txtId" editable="false"/>

            <Label text="Registration"/>
            <ComboBox fx:id="cmbRegistration" prefWidth="300"/>

            <Label text="Payment Date"/>
            <DatePicker fx:id="dpPaymentDate"/>

            <Label text="Amount"/>
            <TextField fx:id="txtAmount" promptText="Enter amount"/>

            <Label text="Status"/>
            <ComboBox fx:id="cmbStatus" prefWidth="300"/>

            <!-- ACTION BUTTONS -->
            <HBox spacing="8">

                <Button fx:id="btnSave"
                        text="Save"
                        onAction="#handleSave"
                        style="-fx-background-color:#7f77dd; -fx-text-fill:white;"/>

                <Button text="Update"
                        onAction="#handleSave"
                        style="-fx-background-color:#2B3990; -fx-text-fill:white;"/>

                <Button text="Delete"
                        onAction="#handleClear"
                        style="-fx-background-color:#e74c3c; -fx-text-fill:white;"/>

                <Button text="Reset"
                        onAction="#handleClear"
                        style="-fx-background-color:#888; -fx-text-fill:white;"/>

            </HBox>

            <!-- REPORT BUTTON -->
            <Button text="Report View"
                    onAction="#handleReportView"
                    prefWidth="300"
                    style="-fx-background-color:#1d9e75;
                           -fx-text-fill:white;
                           -fx-font-weight:bold;
                           -fx-background-radius:8;
                           -fx-cursor:hand;"/>

        </VBox>

        <!-- RIGHT TABLE PANEL -->
        <VBox layoutX="400" layoutY="20" prefWidth="570" spacing="10"
              style="-fx-background-color:white;
                     -fx-padding:20;
                     -fx-background-radius:12;
                     -fx-border-color:#e8e6f8;
                     -fx-border-radius:12;">

            <Label text="Payment List"
                   style="-fx-font-size:16; -fx-font-weight:bold;"/>

            <TextField fx:id="txtSearch"
                       promptText="Search payment..."
                       style="-fx-background-radius:8;"/>

            <TableView fx:id="tblPayment" prefHeight="450">

                <columns>

                    <TableColumn fx:id="colId" text="ID" prefWidth="80"/>
                    <TableColumn fx:id="colRegistration" text="Reg ID" prefWidth="120"/>
                    <TableColumn fx:id="colDate" text="Date" prefWidth="120"/>
                    <TableColumn fx:id="colAmount" text="Amount" prefWidth="100"/>
                    <TableColumn fx:id="colStatus" text="Status" prefWidth="100"/>
                    <TableColumn fx:id="colAction" text="Action" prefWidth="120"/>

                </columns>

            </TableView>

        </VBox>

    </children>

</AnchorPane>
