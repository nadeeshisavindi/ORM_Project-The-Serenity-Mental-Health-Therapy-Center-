<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="1080" prefWidth="1600" style="-fx-background-color:#16213e;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.orm_project.controller.PatientController">

    <children>


        <VBox layoutX="382.0" layoutY="76.0" prefHeight="650.0" prefWidth="350" spacing="12" style="-fx-background-color:white;                      -fx-padding:20;                      -fx-background-radius:12;                      -fx-border-color:#e8e6f8;                      -fx-border-radius:12;">

            <Label style="-fx-font-size:18;-fx-font-weight:bold;-fx-text-fill:#26215c;" text="Patient Management" />

            <Label fx:id="lblMessage" managed="false" prefWidth="310" text="" visible="false" wrapText="true" />

            <Label text="ID" />
            <TextField fx:id="txtId" editable="false" />

            <Label text="Full Name" />
            <TextField fx:id="txtName" promptText="Enter full name" />

            <Label text="NIC" />
            <TextField fx:id="txtNic" promptText="Enter NIC number" />

            <Label text="Email" />
            <TextField fx:id="txtEmail" promptText="Enter email address" />

            <Label text="Phone" />
            <TextField fx:id="txtPhone" promptText="Enter phone number" />

            <Label text="Medical History" />
            <TextArea fx:id="txtMedicalHistory" prefHeight="80" promptText="Enter medical history..." wrapText="true" />

            <HBox spacing="8">
                <Button fx:id="btnSave" onAction="#handleSave" prefHeight="28.0" prefWidth="96.0" style="-fx-background-color:#7f77dd;-fx-text-fill:white;" text="Save" />
                <Button onAction="#handleClear" prefHeight="27.0" prefWidth="95.0" style="-fx-background-color:#e74c3c;-fx-text-fill:white;" text="Delete" />
                <Button onAction="#handleClear" prefHeight="27.0" prefWidth="102.0" style="-fx-background-color:#888;-fx-text-fill:white;" text="Reset" />
            </HBox>

        </VBox>





        <VBox layoutX="751.0" layoutY="76.0" prefHeight="650.0" prefWidth="580" spacing="10" style="-fx-background-color:white;                      -fx-padding:20;                      -fx-background-radius:12;                      -fx-border-color:#e8e6f8;                      -fx-border-radius:12;">

            <Label style="-fx-font-size:16;-fx-font-weight:bold;-fx-text-fill:#26215c;" text="Patient List" />

            <TextField fx:id="txtSearch" promptText="Search patient..." style="-fx-background-radius:8;" />

            <TableView fx:id="tblPatient" prefHeight="500">
                <columns>
                    <TableColumn fx:id="colId" prefWidth="70" text="ID" />
                    <TableColumn fx:id="colName" prefWidth="140" text="Name" />
                    <TableColumn fx:id="colNic" prefWidth="110" text="NIC" />
                    <TableColumn fx:id="colEmail" prefWidth="130" text="Email" />
                    <TableColumn fx:id="colPhone" prefWidth="90" text="Phone" />
                    <TableColumn fx:id="colAction" prefWidth="140" text="Actions" />
                </columns>
            </TableView>

        </VBox>

    </children>
</AnchorPane>
