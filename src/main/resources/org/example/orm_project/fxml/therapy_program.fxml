<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="1080" prefWidth="1600" style="-fx-background-color:#16213e;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.orm_project.controller.TherapyProgramController">

    <children>

        <VBox layoutX="382.0" layoutY="76.0" prefHeight="640.0" prefWidth="350" spacing="12" style="-fx-background-color:white;                      -fx-padding:20;                      -fx-background-radius:12;                      -fx-border-color:#e8e6f8;                      -fx-border-radius:12;">

            <Label style="-fx-font-size:18;-fx-font-weight:bold;-fx-text-fill:#26215c;" text="Therapy Program Management" />

            <Label fx:id="lblMessage" managed="false" prefWidth="310" text="" visible="false" wrapText="true" />

            <Label text="ID" />
            <TextField fx:id="txtId" editable="false" />

            <Label text="Program Name" />
            <TextField fx:id="txtName" promptText="Enter program name" />

            <Label text="Duration (Weeks)" />
            <TextField fx:id="txtDuration" promptText="e.g. 12" />

            <Label text="Fee (LKR)" />
            <TextField fx:id="txtFee" promptText="e.g. 80000" />

            <Label text="Description" />
            <TextField fx:id="txtDescription" promptText="Enter description" />

            <Label text="Therapist" />
            <ComboBox fx:id="cmbTherapist" prefWidth="300" />

            <HBox spacing="8">
                <Button fx:id="btnSave" onAction="#handleSave" prefHeight="25.0" prefWidth="100.0" style="-fx-background-color:#7f77dd;-fx-text-fill:white;" text="Save" />
                <Button onAction="#handleDelete" prefHeight="25.0" prefWidth="99.0" style="-fx-background-color:#e74c3c;-fx-text-fill:white;" text="Delete" />
                <Button onAction="#handleClear" prefHeight="25.0" prefWidth="105.0" style="-fx-background-color:#888;-fx-text-fill:white;" text="Reset" />
            </HBox>

            <Button onAction="#handleReportView" prefWidth="300" style="-fx-background-color:#1d9e75;-fx-text-fill:white;                            -fx-font-weight:bold;-fx-background-radius:8;-fx-cursor:hand;" text="Report View" />

        </VBox>


        <VBox layoutX="751.0" layoutY="76.0" prefHeight="640.0" prefWidth="580" spacing="10" style="-fx-background-color:white;                      -fx-padding:20;                      -fx-background-radius:12;                      -fx-border-color:#e8e6f8;                      -fx-border-radius:12;">

            <Label style="-fx-font-size:16;-fx-font-weight:bold;-fx-text-fill:#26215c;" text="Program List" />

            <TextField fx:id="txtSearch" promptText="Search program..." style="-fx-background-radius:8;" />

            <TableView fx:id="tblProgram" prefHeight="500">
                <columns>
                    <TableColumn fx:id="colId" prefWidth="70" text="ID" />
                    <TableColumn fx:id="colName" prefWidth="150" text="Name" />
                    <TableColumn fx:id="colDuration" prefWidth="80" text="Duration" />
                    <TableColumn fx:id="colFee" prefWidth="90" text="Fee (LKR)" />
                    <TableColumn fx:id="colTherapist" prefWidth="140" text="Therapist" />
                    <TableColumn fx:id="colAction" prefWidth="140" text="Actions" />
                </columns>
            </TableView>

        </VBox>

    </children>
</AnchorPane>
