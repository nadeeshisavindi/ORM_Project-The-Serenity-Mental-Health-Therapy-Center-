<?xml version="1.0" encoding="UTF-8"?>

<?xml version="1.0" encoding="UTF-8"?>

<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              name="payment_report"
              pageWidth="595"
              pageHeight="842"
              columnWidth="555"
              leftMargin="20"
              rightMargin="20"
              topMargin="20"
              bottomMargin="20">

    <!-- QUERY -->
    <queryString>
        <![CDATA[
            SELECT id, payment_date, amount, status
            FROM payment
        ]]>
    </queryString>

    <!-- FIELDS -->
    <field name="id" class="java.lang.String"/>
    <field name="payment_date" class="java.sql.Date"/>
    <field name="amount" class="java.lang.Double"/>
    <field name="status" class="java.lang.String"/>

    <!-- TITLE -->
    <title>
        <band height="60">

            <staticText>
                <reportElement x="0" y="10" width="555" height="30"/>
                <textElement textAlignment="Center">
                    <font size="22" isBold="true"/>
                </textElement>
                <text><![CDATA[Payment Report]]></text>
            </staticText>

            <line>
                <reportElement x="0" y="50" width="555" height="1"/>
            </line>

        </band>
    </title>

    <!-- COLUMN HEADER -->
    <columnHeader>
        <band height="30">

            <staticText>
                <reportElement x="0" y="0" width="120" height="30"/>
                <box>
                    <pen lineWidth="1"/>
                </box>
                <textElement textAlignment="Center">
                    <font isBold="true"/>
                </textElement>
                <text><![CDATA[Payment ID]]></text>
            </staticText>

            <staticText>
                <reportElement x="120" y="0" width="150" height="30"/>
                <box>
                    <pen lineWidth="1"/>
                </box>
                <textElement textAlignment="Center">
                    <font isBold="true"/>
                </textElement>
                <text><![CDATA[Payment Date]]></text>
            </staticText>

            <staticText>
                <reportElement x="270" y="0" width="130" height="30"/>
                <box>
                    <pen lineWidth="1"/>
                </box>
                <textElement textAlignment="Center">
                    <font isBold="true"/>
                </textElement>
                <text><![CDATA[Amount]]></text>
            </staticText>

            <staticText>
                <reportElement x="400" y="0" width="155" height="30"/>
                <box>
                    <pen lineWidth="1"/>
                </box>
                <textElement textAlignment="Center">
                    <font isBold="true"/>
                </textElement>
                <text><![CDATA[Status]]></text>
            </staticText>

        </band>
    </columnHeader>

    <!-- DETAIL -->
    <detail>
        <band height="25">

            <!-- ID -->
            <textField>
                <reportElement x="0" y="0" width="120" height="25"/>
                <box>
                    <pen lineWidth="0.5"/>
                </box>
                <textElement textAlignment="Center"/>
                <textFieldExpression><![CDATA[$F{id}]]></textFieldExpression>
            </textField>

            <!-- DATE -->
            <textField>
                <reportElement x="120" y="0" width="150" height="25"/>
                <box>
                    <pen lineWidth="0.5"/>
                </box>
                <textElement textAlignment="Center"/>
                <textFieldExpression><![CDATA[$F{payment_date}]]></textFieldExpression>
            </textField>

            <!-- AMOUNT -->
            <textField>
                <reportElement x="270" y="0" width="130" height="25"/>
                <box>
                    <pen lineWidth="0.5"/>
                </box>
                <textElement textAlignment="Center"/>
                <textFieldExpression><![CDATA[$F{amount}]]></textFieldExpression>
            </textField>

            <!-- STATUS -->
            <textField>
                <reportElement x="400" y="0" width="155" height="25"/>
                <box>
                    <pen lineWidth="0.5"/>
                </box>
                <textElement textAlignment="Center"/>
                <textFieldExpression><![CDATA[$F{status}]]></textFieldExpression>
            </textField>

        </band>
    </detail>

</jasperReport>