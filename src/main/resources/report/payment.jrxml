<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports
              http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="PaymentReport"
              pageWidth="595" pageHeight="842"
              columnWidth="535" leftMargin="30" rightMargin="30"
              topMargin="20" bottomMargin="20">

    <queryString language="SQL">
        <![CDATA[
        SELECT p.id, p.payment_date, p.amount, p.status, r.id AS reg_id
        FROM payment p
        JOIN registration r ON p.registration_id = r.id
        ORDER BY p.payment_date DESC
        ]]>
    </queryString>

    <field name="id" class="java.lang.String"/>
    <field name="payment_date" class="java.sql.Date"/>
    <field name="amount" class="java.lang.Double"/>
    <field name="status" class="java.lang.String"/>
    <field name="reg_id" class="java.lang.String"/>

    <title>
        <band height="50">
            <staticText>
                <reportElement x="0" y="10" width="535" height="30"/>
                <textElement textAlignment="Center">
                    <font size="18" isBold="true"/>
                </textElement>
                <text><![CDATA[Payment Report - Serenity Wellness Clinic]]></text>
            </staticText>
        </band>
    </title>

    <columnHeader>
        <band height="25">
            <staticText>
                <reportElement x="0" y="0" width="80" height="25" backcolor="#7f77dd" mode="Opaque"/>
                <textElement textAlignment="Center"><font isBold="true" forecolor="#FFFFFF"/></textElement>
                <text><![CDATA[ID]]></text>
            </staticText>
            <staticText>
                <reportElement x="80" y="0" width="120" height="25" backcolor="#7f77dd" mode="Opaque"/>
                <textElement textAlignment="Center"><font isBold="true" forecolor="#FFFFFF"/></textElement>
                <text><![CDATA[Reg ID]]></text>
            </staticText>
            <staticText>
                <reportElement x="200" y="0" width="100" height="25" backcolor="#7f77dd" mode="Opaque"/>
                <textElement textAlignment="Center"><font isBold="true" forecolor="#FFFFFF"/></textElement>
                <text><![CDATA[Date]]></text>
            </staticText>
            <staticText>
                <reportElement x="300" y="0" width="115" height="25" backcolor="#7f77dd" mode="Opaque"/>
                <textElement textAlignment="Center"><font isBold="true" forecolor="#FFFFFF"/></textElement>
                <text><![CDATA[Amount (LKR)]]></text>
            </staticText>
            <staticText>
                <reportElement x="415" y="0" width="120" height="25" backcolor="#7f77dd" mode="Opaque"/>
                <textElement textAlignment="Center"><font isBold="true" forecolor="#FFFFFF"/></textElement>
                <text><![CDATA[Status]]></text>
            </staticText>
        </band>
    </columnHeader>

    <detail>
        <band height="20">
            <textField>
                <reportElement x="0" y="0" width="80" height="20"/>
                <textElement textAlignment="Center"/>
                <textFieldExpression><![CDATA[$F{id}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="80" y="0" width="120" height="20"/>
                <textElement textAlignment="Center"/>
                <textFieldExpression><![CDATA[$F{reg_id}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="200" y="0" width="100" height="20"/>
                <textElement textAlignment="Center"/>
                <textFieldExpression><![CDATA[$F{payment_date}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="300" y="0" width="115" height="20"/>
                <textElement textAlignment="Center"/>
                <textFieldExpression><![CDATA[$F{amount}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="415" y="0" width="120" height="20"/>
                <textElement textAlignment="Center"/>
                <textFieldExpression><![CDATA[$F{status}]]></textFieldExpression>
            </textField>
        </band>
    </detail>

</jasperReport>