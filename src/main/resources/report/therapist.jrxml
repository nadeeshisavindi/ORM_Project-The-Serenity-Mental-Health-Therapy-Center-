<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE jasperReport PUBLIC
        "-//JasperReports//DTD Report Design//EN"
        "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">

<jasperReport name="TherapistReport"
              pageWidth="595" pageHeight="842"
              columnWidth="535" leftMargin="30" rightMargin="30"
              topMargin="20" bottomMargin="20"
              xmlns="http://jasperreports.sourceforge.net/jasperreports">

    <queryString language="SQL">
        <![CDATA[
            SELECT id, name, specialization, phone, email
            FROM therapist
            ORDER BY name
        ]]>
    </queryString>

    <field name="id"             class="java.lang.String"/>
    <field name="name"           class="java.lang.String"/>
    <field name="specialization" class="java.lang.String"/>
    <field name="phone"          class="java.lang.String"/>
    <field name="email"          class="java.lang.String"/>

    <title>
        <band height="60">
            <staticText>
                <reportElement x="0" y="5" width="535" height="35"/>
                <textElement textAlignment="Center">
                    <font size="20" isBold="true"/>
                </textElement>
                <text><![CDATA[Therapist Report]]></text>
            </staticText>
            <staticText>
                <reportElement x="0" y="40" width="535" height="20"/>
                <textElement textAlignment="Center">
                    <font size="11"/>
                </textElement>
                <text><![CDATA[Serenity Wellness Clinic]]></text>
            </staticText>
        </band>
    </title>

    <columnHeader>
        <band height="25">
            <staticText>
                <reportElement x="0"   y="0" width="80"  height="25" backcolor="#7f77dd" mode="Opaque"/>
                <textElement textAlignment="Center"><font isBold="true" forecolor="#FFFFFF"/></textElement>
                <text><![CDATA[ID]]></text>
            </staticText>
            <staticText>
                <reportElement x="80"  y="0" width="130" height="25" backcolor="#7f77dd" mode="Opaque"/>
                <textElement textAlignment="Center"><font isBold="true" forecolor="#FFFFFF"/></textElement>
                <text><![CDATA[Name]]></text>
            </staticText>
            <staticText>
                <reportElement x="210" y="0" width="130" height="25" backcolor="#7f77dd" mode="Opaque"/>
                <textElement textAlignment="Center"><font isBold="true" forecolor="#FFFFFF"/></textElement>
                <text><![CDATA[Specialization]]></text>
            </staticText>
            <staticText>
                <reportElement x="340" y="0" width="90"  height="25" backcolor="#7f77dd" mode="Opaque"/>
                <textElement textAlignment="Center"><font isBold="true" forecolor="#FFFFFF"/></textElement>
                <text><![CDATA[Phone]]></text>
            </staticText>
            <staticText>
                <reportElement x="430" y="0" width="105" height="25" backcolor="#7f77dd" mode="Opaque"/>
                <textElement textAlignment="Center"><font isBold="true" forecolor="#FFFFFF"/></textElement>
                <text><![CDATA[Email]]></text>
            </staticText>
        </band>
    </columnHeader>

    <detail>
        <band height="22">
            <textField>
                <reportElement x="0"   y="0" width="80"  height="22"/>
                <textElement textAlignment="Center"><font size="11"/></textElement>
                <textFieldExpression><![CDATA[$F{id}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="80"  y="0" width="130" height="22"/>
                <textElement textAlignment="Center"><font size="11"/></textElement>
                <textFieldExpression><![CDATA[$F{name}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="210" y="0" width="130" height="22"/>
                <textElement textAlignment="Center"><font size="11"/></textElement>
                <textFieldExpression><![CDATA[$F{specialization}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="340" y="0" width="90"  height="22"/>
                <textElement textAlignment="Center"><font size="11"/></textElement>
                <textFieldExpression><![CDATA[$F{phone}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="430" y="0" width="105" height="22"/>
                <textElement textAlignment="Center"><font size="11"/></textElement>
                <textFieldExpression><![CDATA[$F{email}]]></textFieldExpression>
            </textField>
        </band>
    </detail>

</jasperReport>